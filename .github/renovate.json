{
  "extends": [
    "config:best-practices",
    ":disableRateLimiting"
  ],
  "automerge": false,
  "automergeType": "pr",
  "packageRules": [
    {
      "matchManagers": ["github-actions", "pip_requirements"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["custom.regex", "ansible-galaxy"],
      "automerge": false
    }
  ],
  "enabledManagers": [
    "github-actions",
    "pip_requirements",
    "custom.regex",
    "ansible-galaxy"
  ],
  "ansible-galaxy": {
    "managerFilePatterns": [
      "/^ansible/requirements\\.ya?ml$/"
    ]
  },
  "assignees": ["pluggero"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/vars/virtualbox_guest\\.yml$/",
        "/^.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "virtualbox_guest_virtualbox_version:\\s+\"(?<currentValue>[\\d\\.]+)\"",
        "VBOX_GUEST_VERSION:\\s+\"(?<currentValue>[\\d\\.]+)\""
      ],
      "datasourceTemplate": "custom.virtualbox",
      "depNameTemplate": "virtualbox-role",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "VBOX_VERSION:\\s+\"(?<currentValue>[\\d\\.]+)\""
      ],
      "datasourceTemplate": "custom.virtualbox",
      "depNameTemplate": "virtualbox-ci",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^packer/variables\\.auto\\.pkrvars\\.hcl$/"
      ],
      "matchStrings": [
        "vm_guest_os_version\\s+=\\s+\"(?<currentValue>[\\d\\.]+)\""
      ],
      "datasourceTemplate": "custom.freebsd-installer",
      "depNameTemplate": "freebsd-installer",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^ansible/vars/common_pkgs\\.yml$/"
      ],
      "matchStrings": [
        "py(?<currentValue>\\d+)-ansible"
      ],
      "datasourceTemplate": "custom.ansible-freebsd-pkgname",
      "depNameTemplate": "ansible-freebsd-pkgname",
      "versioningTemplate": "loose"
    }
  ],
  "customDatasources": {
    "virtualbox": {
      "defaultRegistryUrlTemplate": "https://download.virtualbox.org/virtualbox/LATEST-STABLE.TXT",
      "format": "plain"
    },
    "freebsd-installer": {
      "defaultRegistryUrlTemplate": "https://download.freebsd.org/releases/ISO-IMAGES/",
      "format": "html",
      "transformTemplates": [
        "{\"releases\": $map(releases, function($r) { {\"version\": $replace($r.version, /\\/$/, \"\")} })}"
      ]
    },
    "ansible-freebsd-pkgname": {
      "defaultRegistryUrlTemplate": "https://repology.org/api/v1/project/ansible",
      "format": "json",
      "transformTemplates": [
        "{\"releases\": [$map($filter($, function($v){$v.repo=\"freebsd\"}), function($r){ {\"version\": $replace($r.binname, /^py(\\d+)-ansible$/, \"$1\")} })]}"
      ]
    }
  }
}
